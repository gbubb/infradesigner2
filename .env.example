# Copy this file to .env.local and fill in for your environment.
# .env.development is checked in and used automatically by Vite in dev mode.

# URL of the API gateway in front of Postgres (Kong by default).
# Local dev (self-hosted stack from docker-compose.yml): http://localhost:54321
# Remote deployment: the URL of your PostgREST + GoTrue gateway.
VITE_SUPABASE_URL=

# JWT signed with the shared JWT_SECRET, role = anon.
# For local dev, the key in .env.development is pre-generated.
# For remote, generate with a script or use your provider's anon key.
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Backend-only (set in a root `.env` file or your deployment platform, NOT in Vite):
#
#   JWT_SECRET               shared secret that signs VITE_SUPABASE_ANON_KEY.
#                            Min 32 chars. Must match across all services.
#   POSTGRES_PASSWORD        password for the `postgres` superuser role.
#                            Defaults to `postgres` in docker-compose.yml.
#   AUTHENTICATOR_PASSWORD   password for the PostgREST `authenticator` role.
#                            Set by docker/postgres/init/02-post-restore.sh and
#                            used in PGRST_DB_URI. Defaults to `postgres`.
#   AUTH_ADMIN_PASSWORD      password for the GoTrue `supabase_auth_admin` role.
#                            Set by docker/postgres/init/02-post-restore.sh and
#                            used in GOTRUE_DB_DATABASE_URL. Defaults to `postgres`.
#
# For production: generate strong values for each and inject via your deploy
# platform's secrets mechanism. Do NOT reuse the dev defaults.
